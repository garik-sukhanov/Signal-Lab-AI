{
  "name": "signal-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Signal Lab platform foundation monorepo",
  "scripts": {
    "frontend:dev": "npm run dev --prefix apps/frontend",
    "backend:dev": "npm run start:dev --prefix apps/backend",
    "frontend:build": "npm run build --prefix apps/frontend",
    "backend:build": "npm run build --prefix apps/backend",
    "frontend:lint": "npm run lint --prefix apps/frontend",
    "backend:lint": "npm run lint --prefix apps/backend",
    "prisma:generate": "sh -ac 'set -a; [ -f .env ] && . ./.env; set +a; npm run prisma:generate --prefix apps/backend'",
    "prisma:migrate": "sh -ac 'set -a; [ -f .env ] && . ./.env; set +a; npm run prisma:migrate --prefix apps/backend'"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
