generator client {
  provider = "prisma-client-js"
  output   = "../apps/backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScenarioRun {
  id        String   @id @default(cuid())
  type      String
  status    String
  duration  Int?
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())
}
